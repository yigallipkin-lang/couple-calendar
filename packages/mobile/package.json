{
  "name": "@couple-calendar/mobile",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@couple-calendar/shared": "workspace:*",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "^50.0.0",
    "expo-firebase-analytics": "^6.0.0",
    "expo-notifications": "^0.27.0",
    "expo-splash-screen": "^0.26.4",
    "firebase": "^10.5.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.27.0"
  },
  "devDependencies": {
    "@expo/metro-runtime": "~3.1.3",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "react-native-web": "~0.19.13",
    "typescript": "^5.3.0"
  },
  "expo": {
    "name": "Couple Calendar",
    "slug": "couple-calendar",
    "version": "0.1.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.couplecalendar.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.couplecalendar.app"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "default"
          ],
          "targetProjectVersion": "33"
        }
      ]
    ]
  }
}
